# --- 2. UNION-FIND (DISJOINT SET UNION) DATA STRUCTURE ---
class UnionFind:
    def __init__(self):
        self.parent = {}
    def find(self, i):
        if i not in self.parent:
            self.parent[i] = i
        if self.parent[i] == i:
            return i
        self.parent[i] = self.find(self.parent[i])
        return self.parent[i]
    def union(self, i, j):
        root_i = self.find(i)
        root_j = self.find(j)
        if root_i != root_j:
            self.parent[root_i] = root_j


# --- 3. DUAL-GATE GLOBAL SEGMENT VERIFIER ---
def verify_segment_similarity(y_a, y_b, sr=TARGET_SR):
    if len(y_a) == 0 or len(y_b) == 0:
        return False
        
    # Gate 1: Chord Alignment (Chroma STFT DTW)
    chroma_a = librosa.feature.chroma_stft(y=y_a, sr=sr, hop_length=1024)
    chroma_b = librosa.feature.chroma_stft(y=y_b, sr=sr, hop_length=1024)
    
    if chroma_a.shape[1] < 5 or chroma_b.shape[1] < 5:
        return False
        
    dist_matrix_chroma = cdist(chroma_a.T, chroma_b.T, metric='cosine')
    
    from librosa.sequence import dtw
    try:
        step_sizes_sigma = np.array([[1, 1], [0, 1], [1, 0]])
        weights_mul = np.array([1.0, 2.0, 2.0])
        D_cost, wp = dtw(C=dist_matrix_chroma, step_sizes_sigma=step_sizes_sigma, weights_mul=weights_mul)
        norm_cost_chroma = D_cost[-1, -1] / (len(wp) + 1e-9)
    except Exception:
        return False
        
    # Gate 2: Acoustic Fingerprint (Global Timbre MFCC Cosine Distance)
    mfcc_a = librosa.feature.mfcc(y=y_a, sr=sr, n_mfcc=13, hop_length=1024)
    mfcc_b = librosa.feature.mfcc(y=y_b, sr=sr, n_mfcc=13, hop_length=1024)
    
    mean_mfcc_a = np.mean(mfcc_a, axis=1)
    mean_mfcc_b = np.mean(mfcc_b, axis=1)
    timbral_dist = cdist(mean_mfcc_a[np.newaxis, :], mean_mfcc_b[np.newaxis, :], metric='cosine')[0, 0]
    
    return (norm_cost_chroma < 0.22) and (timbral_dist < 0.08)


# --- 4. LONG-FORM CROSS-SIMILARITY SEARCH ---
def search_longform_repeats(y_1, y_2, sr, min_sec=MIN_MATCH_SEC, thresh=MATCH_THRESH, is_self=False):
    max_len = max(len(y_1), len(y_2))
    if max_len > 10 * 60 * sr:    
        hop = 16384
    elif max_len > 3 * 60 * sr:   
        hop = 8192
    else:
        hop = 4096
        
    chroma_1 = librosa.feature.chroma_stft(y=y_1, sr=sr, hop_length=hop)
    chroma_2 = librosa.feature.chroma_stft(y=y_2, sr=sr, hop_length=hop)
    
    N1 = chroma_1.shape[1]
    N2 = chroma_2.shape[1]
    
    rms_1 = np.zeros(N1)
    rms_2 = np.zeros(N2)
    for i in range(N1):
        chunk = y_1[i*hop : (i+1)*hop]
        if len(chunk) > 0:
            rms_1[i] = np.sqrt(np.mean(chunk**2) + 1e-9)
    for j in range(N2):
        chunk = y_2[j*hop : (j+1)*hop]
        if len(chunk) > 0:
            rms_2[j] = np.sqrt(np.mean(chunk**2) + 1e-9)
            
    D = cdist(chroma_1.T, chroma_2.T, metric='cosine')
    
    for i in range(N1):
        for j in range(N2):
            if rms_1[i] < SILENCE_THRESH or rms_2[j] < SILENCE_THRESH:
                D[i, j] = 1.0
                
    min_frames = int((min_sec * sr) / hop)
    matches = []
    
    start_offset = min_frames if is_self else -N1 + min_frames
    
    for d in range(start_offset, N2 - min_frames):
        diag = np.diagonal(D, offset=d)
        smoothed = uniform_filter1d(diag, size=max(5, min_frames // 4))
        under_thresh = smoothed < thresh
        
        run_start = None
        for idx, val in enumerate(under_thresh):
            if val and run_start is None:
                run_start = idx
            elif not val and run_start is not None:
                run_len = idx - run_start
                if run_len >= min_frames:
                    if d >= 0:
                        f1_start, f2_start = run_start, run_start + d
                    else:
                        f1_start, f2_start = run_start - d, run_start
                        
                    matches.append({
                        'f1_start': f1_start,
                        'f1_end': f1_start + run_len,
                        'f2_start': f2_start,
                        'f2_end': f2_start + run_len,
                        'mean_dist': np.mean(diag[run_start:idx])
                    })
                run_start = None
                
        if run_start is not None:
            run_len = len(under_thresh) - run_start
            if run_len >= min_frames:
                if d >= 0:
                    f1_start, f2_start = run_start, run_start + d
                else:
                    f1_start, f2_start = run_start - d, run_start
                matches.append({
                    'f1_start': f1_start,
                    'f1_end': f1_start + run_len,
                    'f2_start': f2_start,
                    'f2_end': f2_start + run_len,
                    'mean_dist': np.mean(diag[run_start:])
                })
                
    return matches, hop


# --- 5. GRAPH CLUSTERING LAYER (EQUIVALENCE SET GROUPER) ---
def cluster_and_group_segments(raw_matches, hop, sr):
    canonical_segments = [] 
    uf = UnionFind()
    
    def find_or_create_canonical(file_idx, start, end):
        length = end - start
        for seg in canonical_segments:
            if seg['file_idx'] == file_idx:
                overlap = max(0, min(end, seg['end']) - max(start, seg['start']))
                if overlap > 0.4 * length or overlap > 0.4 * (seg['end'] - seg['start']):
                    seg['start'] = min(seg['start'], start)
                    seg['end'] = max(seg['end'], end)
                    return seg['id']
        new_id = len(canonical_segments)
        canonical_segments.append({'id': new_id, 'file_idx': file_idx, 'start': start, 'end': end})
        return new_id
        
    for m in raw_matches:
        f1, s1, e1, f2, s2, e2, dist = m
        id_1 = find_or_create_canonical(f1, s1, e1)
        id_2 = find_or_create_canonical(f2, s2, e2)
        uf.union(id_1, id_2)
        
    groups = {}
    for seg in canonical_segments:
        root = uf.find(seg['id'])
        if root not in groups:
            groups[root] = []
        groups[root].append(seg)
        
    valid_groups = []
    for root, segs in groups.items():
        if len(segs) >= 2:
            segs = sorted(segs, key=lambda x: (x['file_idx'], x['start']))
            valid_groups.append(segs)
            
    return valid_groups


# --- 6. DUAL-TRACK ALIGNMENT ENGINE (CONSTRAINT-TIGHTENED) ---
def align_track_slices(y_a, y_b):
    chroma_a = librosa.feature.chroma_stft(y=y_a, sr=TARGET_SR, hop_length=512)
    chroma_b = librosa.feature.chroma_stft(y=y_b, sr=TARGET_SR, hop_length=512)
    
    dist_matrix = cdist(chroma_a.T, chroma_b.T, metric='cosine')
    
    from librosa.sequence import dtw
    
    step_sizes_sigma = np.array([[1, 1], [0, 1], [1, 0]])
    weights_mul = np.array([1.0, 2.0, 2.0])
    
    _, wp = dtw(C=dist_matrix, step_sizes_sigma=step_sizes_sigma, weights_mul=weights_mul)
    wp = wp[::-1]
    
    hop_size = 512
    aligned_y_a, aligned_y_b = [], []
    
    for idx_a, idx_b in wp:
        start_a, end_a = idx_a * hop_size, (idx_a + 1) * hop_size
        start_b, end_b = idx_b * hop_size, (idx_b + 1) * hop_size
        chunk_a = y_a[start_a:end_a]
        chunk_b = y_b[start_b:end_b]
        
        min_len = min(len(chunk_a), len(chunk_b))
        if min_len > 0:
            aligned_y_a.extend(chunk_a[:min_len])
            aligned_y_b.extend(chunk_b[:min_len])
            
    return np.array(aligned_y_a, dtype=np.float32), np.array(aligned_y_b, dtype=np.float32), wp, hop_size


# --- 7. DETERMINISTIC PROJECTIVE MULTI-HEADED NMF ENGINE ---
def process_projective_nmf(y_a, y_b, k=NUM_HEADS, max_iter=30):
    stft_a = librosa.stft(y_a, n_fft=1024, hop_length=256)
    stft_b = librosa.stft(y_b, n_fft=1024, hop_length=256)
    
    V_a = np.abs(stft_a) + 1e-9
    V_b = np.abs(stft_b) + 1e-9
    F, T = V_a.shape
    
    np.random.seed(42)
    W = np.random.rand(F, k) + 1e-5
    H_a = np.random.rand(k, T) + 1e-5
    
    for i in range(max_iter):
        V_approx_a = W @ H_a + 1e-9
        H_a = H_a * (W.T @ (V_a / V_approx_a)) / (W.T @ np.ones((F, T)) + 1e-9)
        V_approx_a = W @ H_a + 1e-9
        W = W * ((V_a / V_approx_a) @ H_a.T) / (np.ones((F, T)) @ H_a.T + 1e-9)
        
    np.random.seed(42)
    H_b = np.random.rand(k, T) + 1e-5
    for i in range(max_iter):
        V_approx_b = W @ H_b + 1e-9
        H_b = H_b * (W.T @ (V_b / V_approx_b)) / (W.T @ np.ones((F, T)) + 1e-9)
        
    freqs = np.linspace(0, TARGET_SR / 2, F)
    centroids = []
    for j in range(k):
        centroid_j = np.sum(freqs * W[:, j]) / (np.sum(W[:, j]) + 1e-9)
        centroids.append(centroid_j)
        
    sorted_indices = np.argsort(centroids)
    labels_map = {}
    if k == 3:
        labels_map[sorted_indices[0]] = "Bass / Kick Resonance"
        labels_map[sorted_indices[1]] = "Melodic Harmonics (Guitar/Keys/Vocals)"
        labels_map[sorted_indices[2]] = "High Transients (Drums/Percussion)"
    else:
        for rank, idx in enumerate(sorted_indices):
            labels_map[idx] = f"Source Cluster {rank} ({centroids[idx]:.0f}Hz)"
            
    sources_a, sources_b, head_names = [], [], []
    
    for j in range(k):
        mask_a = (W[:, [j]] @ H_a[[j], :]) / (W @ H_a + 1e-9)
        mask_b = (W[:, [j]] @ H_b[[j], :]) / (W @ H_b + 1e-9)
        
        sig_a = librosa.istft(stft_a * mask_a, hop_length=256)
        sig_b = librosa.istft(stft_b * mask_b, hop_length=256)
        
        for list_sig, original_sig in [(sources_a, sig_a), (sources_b, sig_b)]:
            sig_padded = original_sig
            if len(sig_padded) < len(y_a):
                sig_padded = np.pad(sig_padded, (0, len(y_a) - len(sig_padded)))
            else:
                sig_padded = sig_padded[:len(y_a)]
            list_sig.append(sig_padded)
            
        head_names.append(labels_map[j])
            
    return sources_a, sources_b, head_names


# --- 8. TOPOLOGICAL EMBEDDING HEADS ---
class MultiHeadAgent:
    def __init__(self, head_id, track_label, audio, sr, source_name):
        self.id = head_id
        self.source_name = source_name
        self.label = f"{track_label} Head {head_id}"
        self.audio = audio
        
        tau = int(sr * (TAU_MS / 1000.0))
        self.x = audio[:-2*tau]
        self.y_del = audio[tau:-tau]
        self.z_del = audio[2*tau:]
        
        self.radius = np.sqrt(self.x**2 + self.y_del**2 + self.z_del**2) + 1e-8
        
        dx = np.gradient(self.x)
        dy = np.gradient(self.y_del)
        dz = np.gradient(self.z_del)
        ddx = np.gradient(dx)
        ddy = np.gradient(dy)
        ddz = np.gradient(dz)
        dddx = np.gradient(ddx)
        dddy = np.gradient(ddy)
        dddz = np.gradient(dz)
        self.jerk = np.sqrt(dddx**2 + dddy**2 + dddz**2) + 1e-8


# --- 9. FORENSIC SWEEP ENGINE (ALL-DISCREPANCY GENERATOR) ---
def perform_deep_discrepancy_sweep(y_a, y_b, wp, dtw_hop, head_names, sources_a, sources_b, b_start, i_start):
    anomalies = []
    
    # 1. TEMPO CHECK (Estimated Global BPM)
    try:
        tempo_a, _ = librosa.beat.beat_track(y=y_a, sr=TARGET_SR)
        tempo_b, _ = librosa.beat.beat_track(y=y_b, sr=TARGET_SR)
        
        t_a = float(tempo_a[0]) if isinstance(tempo_a, np.ndarray) else float(tempo_a)
        t_b = float(tempo_b[0]) if isinstance(tempo_b, np.ndarray) else float(tempo_b)
        tempo_diff = t_b - t_a
        
        if np.abs(tempo_diff) > 0.1:
            anomalies.append({
                'time': 0.0,
                'category': "Tempo Variance",
                'severity': "🟡 MEDIUM",
                'desc': f"Global Tempo Difference. Track A: {t_a:.1f} BPM, Track B: {t_b:.1f} BPM (Drift: {tempo_diff:+.1f} BPM)."
            })
    except Exception as e:
        print(f"⚠️ [Sweep] Tempo tracking warning: {e}")

    # 2. RHYTHMIC TIMING DRIFT
    wp_array = np.array(wp)
    time_a = wp_array[:, 0] * dtw_hop / TARGET_SR
    time_b = wp_array[:, 1] * dtw_hop / TARGET_SR
    offsets = time_b - time_a
    smoothed_offsets = uniform_filter1d(offsets, size=int(TARGET_SR / dtw_hop * 2.0))
    
    peak_drift_idx = np.argmax(np.abs(smoothed_offsets))
    peak_offset = smoothed_offsets[peak_drift_idx]
    
    if np.abs(peak_offset) > 0.04:
        dir_label = "early" if peak_offset < 0 else "late"
        anomalies.append({
            'time': time_a[peak_drift_idx],
            'category': "Rhythmic Timing",
            'severity': "🔴 HIGH" if np.abs(peak_offset) > 0.50 else "🟡 MEDIUM",
            'desc': f"Transient alignment offset detected: Track B is running {np.abs(peak_offset):.3f}s {dir_label}."
        })

    # 3. DYNAMIC COMPRESSION (Crest Factor)
    crest_a = np.max(np.abs(y_a)) / (np.sqrt(np.mean(y_a**2)) + 1e-9)
    crest_b = np.max(np.abs(y_b)) / (np.sqrt(np.mean(y_b**2)) + 1e-9)
    db_diff = 20 * np.log10(crest_b / crest_a)
    
    if np.abs(db_diff) > 0.8:
        action = "more compressed" if db_diff < 0 else "more dynamic"
        anomalies.append({
            'time': 0.0,
            'category': "Dynamic Compression",
            'severity': "🔵 INFO",
            'desc': f"Track B is {np.abs(db_diff):.1f} dB {action} than Track A (mismatched mastering limiter thresholds)."
        })

    # 4. SPECTRAL EQUALIZATION (EQ)
    spec_a = np.abs(librosa.stft(y_a, n_fft=1024))
    spec_b = np.abs(librosa.stft(y_b, n_fft=1024))
    mean_spec_a = np.mean(spec_a, axis=1)
    mean_spec_b = np.mean(spec_b, axis=1)
    
    freqs = np.linspace(0, TARGET_SR/2, len(mean_spec_a))
    
    bass_ratio = np.mean(mean_spec_b[freqs < 150]) / (np.mean(mean_spec_a[freqs < 150]) + 1e-9)
    mid_ratio = np.mean(mean_spec_b[(freqs >= 150) & (freqs < 4000)]) / (np.mean(mean_spec_a[(freqs >= 150) & (freqs < 4000)]) + 1e-9)
    high_ratio = np.mean(mean_spec_b[freqs >= 4000]) / (np.mean(mean_spec_a[freqs >= 4000]) + 1e-9)
    
    for band_name, ratio in [("Bass (<150Hz)", bass_ratio), ("Midrange", mid_ratio), ("Treble (>4kHz)", high_ratio)]:
        db_shift = 20 * np.log10(ratio)
        if np.abs(db_shift) > 1.2:
            direction = "boost" if db_shift > 0 else "cut"
            anomalies.append({
                'time': 0.0,
                'category': "Spectral Balance",
                'severity': "🔵 INFO",
                'desc': f"EQ shift detected: {band_name} is altered by a {np.abs(db_shift):.1f} dB {direction} in Track B."
            })

    # 5. VOCAL MELODY / INTONATION CHECK
    vocal_a = sources_a[1]
    vocal_b = sources_b[1]
    try:
        f0_a = librosa.yin(y=vocal_a, sr=TARGET_SR, fmin=80, fmax=500, hop_length=512)
        f0_b = librosa.yin(y=vocal_b, sr=TARGET_SR, fmin=80, fmax=500, hop_length=512)
        v_rms_a = librosa.feature.rms(y=vocal_a, frame_length=1024, hop_length=512)[0]
        v_rms_b = librosa.feature.rms(y=vocal_b, frame_length=1024, hop_length=512)[0]
        
        voiced_mask = (v_rms_a > 0.02) & (v_rms_b > 0.02) & (f0_a > 0) & (f0_b > 0)
        if np.sum(voiced_mask) > 10:
            pitch_corr = np.corrcoef(f0_a[voiced_mask], f0_b[voiced_mask])[0, 1]
            anomalies.append({
                'time': 0.0,
                'category': "Melody Profile",
                'severity': "🔵 INFO",
                'desc': f"Overall Vocal Melodic Correlation across tracked frames is {pitch_corr*100:.1f}%."
            })
        
        for i in range(min(len(f0_a), len(f0_b))):
            if v_rms_a[i] > 0.02 and v_rms_b[i] > 0.02:
                p_a, p_b = f0_a[i], f0_b[i]
                if p_a > 0 and p_b > 0:
                    diff_semi = 12 * np.log2(p_b / p_a)
                    if 0.8 <= np.abs(diff_semi) < 5.0:
                        intonation = "sharper" if diff_semi > 0 else "flatter"
                        anomalies.append({
                            'time': i * 512 / TARGET_SR,
                            'category': "Vocal Intonation",
                            'severity': "🟡 MEDIUM",
                            'desc': f"Melodic pitch deviation: Vocalist is singing {np.abs(diff_semi):.2f} semitones {intonation}."
                        })
    except Exception as e:
        print(f"⚠️ [Sweep] Melody tracking warning: {e}")

    # 6. LYRICS / PHONETICS CHECK
    try:
        mfcc_a = librosa.feature.mfcc(y=vocal_a, sr=TARGET_SR, n_mfcc=13, hop_length=512)
        mfcc_b = librosa.feature.mfcc(y=vocal_b, sr=TARGET_SR, n_mfcc=13, hop_length=512)
        min_f = min(mfcc_a.shape[1], mfcc_b.shape[1])
        
        v_rms_a_frames = librosa.feature.rms(y=vocal_a, frame_length=1024, hop_length=512)[0][:min_f]
        voiced_frames = v_rms_a_frames > 0.03
        if np.sum(voiced_frames) > 5:
            dists = [cdist(mfcc_a[:, [idx]].T, mfcc_b[:, [idx]].T, metric='cosine')[0, 0] for idx in range(min_f) if voiced_frames[idx]]
            global_mismatch = np.mean(dists)
            anomalies.append({
                'time': 0.0,
                'category': "Lyrics Mismatch",
                'severity': "🟡 MEDIUM" if global_mismatch > 0.20 else "🔵 INFO",
                'desc': f"Global Lyrical Phonetic Mismatch score calculated at {global_mismatch*100:.1f}%."
            })
        
        for i in range(min_f):
            if v_rms_a_frames[i] > 0.03:
                dist = cdist(mfcc_a[:, [i]].T, mfcc_b[:, [i]].T, metric='cosine')[0, 0]
                if dist > 0.20:
                    anomalies.append({
                        'time': i * 512 / TARGET_SR,
                        'category': "Lyrical Phonetics",
                        'severity': "🟡 MEDIUM",
                        'desc': f"Pronunciation shift / word variation (vocal tract envelope mismatch of {dist*100:.1f}%)."
                    })
    except Exception as e:
        print(f"⚠️ [Sweep] Lyric tracking warning: {e}")

    anomalies = sorted(anomalies, key=lambda x: x['time'])
    return anomalies


# --- 10. TOPOLOGICAL VOCAL KNOT GENERATOR ---
def generate_topological_vocal_knots(set_idx, inst_idx, clean_name, sources_a, sources_b, anomalies, timestamp):
    """
    Slices isolated vocal tracks into 5-second windows [T-2.5s, T+2.5s] centered
    on each vocal or timing anomaly, reconstructing them as 3D delay-coordinate knots.
    """
    vocal_a = sources_a[1]  # Vocal Head
    vocal_b = sources_b[1]  # Vocal Head
    vocal_len = len(vocal_a)
    
    # Isolate relevant vocal or phonetic deviations
    vocal_anomalies = [am for am in anomalies if am['time'] > 0.0 and am['category'] in ["Vocal Intonation", "Lyrical Phonetics"]]
    
    if not vocal_anomalies:
        print(f"📍 [Knots] No vocal-specific inflection points located for Song Set {set_idx}.")
        return []
        
    print(f"📍 [Knots] Constructing {len(vocal_anomalies)} vocal knots centered on key inflection points...")
    
    pdf_filename = f"set_{set_idx}_{clean_name}_vocal_knots_{timestamp}.pdf"
    
    tau = int(TARGET_SR * (TAU_MS / 1000.0))  # 10ms delay koordinat
    span_samples = int(2.5 * TARGET_SR)      # 2.5 seconds half-width
    ds = 15                                   # Downsample factor for clean lines
    
    knot_files = []
    
    with PdfPages(pdf_filename) as pdf:
        for idx, am in enumerate(vocal_anomalies):
            t_center = am['time']
            sample_center = int(t_center * TARGET_SR)
            
            # Enforce strict boundary safety (no out-of-bounds indexing)
            start_idx = max(0, sample_center - span_samples)
            end_idx = min(vocal_len, sample_center + span_samples)
            
            # Extract corresponding 5-second slices
            slice_a = vocal_a[start_idx:end_idx]
            slice_b = vocal_b[start_idx:end_idx]
            
            if len(slice_a) < 3 * tau:
                continue
                
            # Reconstruct 3D delay coordinates for Track A
            x_a = slice_a[:-2*tau]
            y_del_a = slice_a[tau:-tau]
            z_del_a = slice_a[2*tau:]
            
            # Reconstruct 3D delay coordinates for Track B
            x_b = slice_b[:-2*tau]
            y_del_b = slice_b[tau:-tau]
            z_del_b = slice_b[2*tau:]
            
            # Render Comparative 3D Phase Plot
            fig = plt.figure(figsize=(10, 8))
            ax = fig.add_subplot(111, projection='3d')
            
            ax.plot(x_a[::ds], y_del_a[::ds], z_del_a[::ds], label='Track A (Baseline)', color='#1f77b4', alpha=0.5, lw=1.2, rasterized=True)
            ax.plot(b.audio[:-2*tau][::ds] if 'b' in locals() else x_b[::ds], 
                    b.audio[tau:-tau][::ds] if 'b' in locals() else y_del_b[::ds], 
                    b.audio[2*tau:][::ds] if 'b' in locals() else z_del_b[::ds], 
                    label='Track B (Instance)', color='#ff7f0e', alpha=0.6, lw=1.2, rasterized=True)
            
            ax.set_title(f"Vocal Knot at {t_center:.2f}s (Set {set_idx})\nAnomaly: {am['desc']}", fontsize=11, fontweight='bold', pad=10)
            ax.set_xticklabels([]); ax.set_yticklabels([]); ax.set_zticklabels([])
            ax.xaxis.set_pane_color((1.0, 1.0, 1.0, 0.0)); ax.yaxis.set_pane_color((1.0, 1.0, 1.0, 0.0)); ax.zaxis.set_pane_color((1.0, 1.0, 1.0, 0.0))
            ax.set_box_aspect([1, 1, 1])
            ax.view_init(elev=20, azim=45)
            ax.legend(loc='upper right', frameon=True, fontsize=9)
            
            pdf.savefig(fig, dpi=300)
            plt.close(fig)
            
    print(f"💾 [Knots] Compiled multi-page vocal knot report to '{pdf_filename}'")
    return [pdf_filename]


