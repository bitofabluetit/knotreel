# --- 12. N-WAY COUPLING COORDINATOR ENGINE ---
def run_nway_topological_pipeline(file_paths):
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    print(f"\n🚀 [System] Initializing N-Way Pipeline on {len(file_paths)} Long-Form files...")
    
    waveforms = []
    file_names = []
    for path in file_paths:
        y, _ = librosa.load(path, sr=TARGET_SR)
        waveforms.append(y)
        file_names.append(os.path.basename(path))
        
    num_files = len(file_paths)
    raw_matches = []
    hop = 4096
    
    print("⏳ [MIR Engine] Conducting searches...")
    for i in range(num_files):
        for j in range(i, num_files):
            is_self = (i == j)
            matches_ij, hop = search_longform_repeats(
                waveforms[i], waveforms[j], TARGET_SR, is_self=is_self
            )
            for m in matches_ij:
                start_sec_1 = (m['f1_start'] * hop) / TARGET_SR
                end_sec_1 = (m['f1_end'] * hop) / TARGET_SR
                start_sec_2 = (m['f2_start'] * hop) / TARGET_SR
                end_sec_2 = (m['f2_end'] * hop) / TARGET_SR
                
                y_slice_1 = waveforms[i][int(start_sec_1 * TARGET_SR):int(end_sec_1 * TARGET_SR)]
                y_slice_2 = waveforms[j][int(start_sec_2 * TARGET_SR):int(end_sec_2 * TARGET_SR)]
                
                if verify_segment_similarity(y_slice_1, y_slice_2):
                    raw_matches.append((
                        i, m['f1_start'], m['f1_end'], 
                        j, m['f2_start'], m['f2_end'], 
                        m['mean_dist']
                    ))
                
    song_sets = cluster_and_group_segments(raw_matches, hop, TARGET_SR)
    
    if not song_sets:
        print("❌ [MIR Engine] No matching repeating song components found across files.")
        return
        
    print(f"🎯 [MIR Engine] Resolved {len(song_sets)} unique verified Song Sets.")
    
    text_report_path = f"discrepancy_report_{timestamp}.txt"
    with open(text_report_path, "w", encoding="utf-8") as log:
        log.write("=================================================================================\n")
        log.write(" 📟 APEX N-WAY MULTI-REPEAT ANALYSIS DISCREPANCY REPORT\n")
        log.write("=================================================================================\n")
        log.write(f"Execution Run Timestamp: {timestamp}\n")
        log.write("Source Files Evaluated:\n")
        for idx, fn in enumerate(file_names):
            log.write(f"  • File {idx}: {fn}\n")
        log.write(f"Total Song Sets Identified: {len(song_sets)}\n\n")

    for set_idx, group in enumerate(song_sets):
        baseline_meta = group[0]
        b_file_idx = baseline_meta['file_idx']
        b_start_sec = (baseline_meta['start'] * hop) / TARGET_SR
        b_end_sec = (baseline_meta['end'] * hop) / TARGET_SR
        
        y_baseline_slice = waveforms[b_file_idx][int(b_start_sec*TARGET_SR) : int(b_end_sec*TARGET_SR)]
        ref_duration_samples = len(y_baseline_slice)
        
        fn_baseline = f"set_{set_idx}_instance_0_ref_{timestamp}.wav"
        scaled_base = np.clip(y_baseline_slice, -1.0, 1.0) * 32767.0
        wav_write(fn_baseline, TARGET_SR, scaled_base.astype(np.int16))
        
        dummy_align, _, _, _ = align_track_slices(y_baseline_slice, y_baseline_slice)
        _, _, head_names = process_projective_nmf(dummy_align, dummy_align, k=NUM_HEADS)
        
        clean_song_name = head_names[1].replace(" ", "_").replace("/", "_").replace("(", "").replace(")", "")
        
        print(f"\n=================================================================================")
        print(f" 📦 PROCESSING SONG SET {set_idx+1} / {len(song_sets)} ({clean_song_name})")
        print(f"=================================================================================")

        with open(text_report_path, "a", encoding="utf-8") as log:
            log.write(f"---------------------------------------------------------------------------------\n")
            log.write(f" 📦 SONG SET #{set_idx}: {clean_song_name} ({len(group)} instances)\n")
            log.write(f"---------------------------------------------------------------------------------\n")
            log.write(f" ⭐ Baseline Reference (Instance 0):\n")
            log.write(f"    - Located in : File {b_file_idx} ({file_names[b_file_idx]})\n")
            log.write(f"    - Timeline   : {b_start_sec:.2f}s to {b_end_sec:.2f}s\n")
            log.write(f"    - Output File: {fn_baseline}\n\n")
            
        for inst_idx, inst_meta in enumerate(group[1:], start=1):
            i_file_idx = inst_meta['file_idx']
            i_start_sec = (inst_meta['start'] * hop) / TARGET_SR
            
            i_start_frame = int(i_start_sec * TARGET_SR)
            y_inst_slice = waveforms[i_file_idx][i_start_frame : i_start_frame + ref_duration_samples]
            
            if len(y_inst_slice) < ref_duration_samples:
                pad_len = ref_duration_samples - len(y_inst_slice)
                y_inst_slice = np.pad(y_inst_slice, (0, pad_len))
            
            fn_inst = f"set_{set_idx}_instance_{inst_idx}_{timestamp}.wav"
            scaled_inst = np.clip(y_inst_slice, -1.0, 1.0) * 32767.0
            wav_write(fn_inst, TARGET_SR, scaled_inst.astype(np.int16))
            
            print(f" 🔍 Comparing Baseline (Instance 0) vs Instance {inst_idx}...")
            
            y_aligned_a, y_aligned_b, wp, dtw_hop = align_track_slices(y_baseline_slice, y_inst_slice)
            sources_a, sources_b, head_names = process_projective_nmf(y_aligned_a, y_aligned_b, k=NUM_HEADS)
            
            print("🧠 [Semantic Engine] Running analysis sweep...")
            anomalies = perform_deep_discrepancy_sweep(
                y_baseline_slice, y_inst_slice, wp, dtw_hop, head_names, sources_a, sources_b, b_start_sec, i_start_sec
            )
            
            # ---------------------------------------------------------------------------
            # TOPOLOGICAL VOCAL KNOT PROCESSING STEP
            # ---------------------------------------------------------------------------
            generate_topological_vocal_knots(set_idx, inst_idx, clean_song_name, sources_a, sources_b, anomalies, timestamp)
            
            agents_a = [MultiHeadAgent(i, "Baseline", sources_a[i], TARGET_SR, head_names[i]) for i in range(NUM_HEADS)]
            agents_b = [MultiHeadAgent(i, f"Inst {inst_idx}", sources_b[i], TARGET_SR, head_names[i]) for i in range(NUM_HEADS)]
            
            discrepancies = {}
            for k in range(NUM_HEADS):
                a_head, b_head = agents_a[k], agents_b[k]
                diff = np.sqrt((a_head.x - b_head.x)**2 + (a_head.y_del - b_head.y_del)**2 + (a_head.z_del - b_head.z_del)**2)
                smoothed_diff = uniform_filter1d(diff, size=int(TARGET_SR * 0.15))
                max_idx = np.argmax(smoothed_diff)
                
                discrepancies[k] = {
                    'smoothed_diff': smoothed_diff,
                    'mean_diff': np.mean(smoothed_diff),
                    'max_diff': np.max(smoothed_diff),
                    'max_time': max_idx / TARGET_SR
                }
                
            pdf_fn = f"set_{set_idx}_{clean_song_name}_vs_inst_{inst_idx}_{timestamp}.pdf"
            
            draw_detailed_discrepancy_pdf(
                set_idx, inst_idx, clean_song_name, agents_a, agents_b, discrepancies, 
                anomalies, pdf_fn, b_start_sec, i_start_sec
            )
            
            with open(text_report_path, "a", encoding="utf-8") as log:
                log.write(f" 🔸 Comparison: Reference vs Instance {inst_idx}\n")
                log.write(f"    - Instance Location: File {i_file_idx} ({file_names[i_file_idx]})\n")
                log.write(f"    - Instance Timeline: {i_start_sec:.2f}s to {(i_start_sec + (ref_duration_samples/TARGET_SR)):.2f}s\n")
                log.write(f"    - Output WAV Segment: {fn_inst}\n")
                log.write(f"    - Dashboard PDF     : {pdf_fn}\n\n")
                
                log.write("====== 🧠 APEX SEMANTIC MACRO INTERPRETATION ======\n")
                for am in anomalies:
                    rel_t = am['time']
                    master_a_t = b_start_sec + rel_t if rel_t != 0.0 else 0.0
                    master_b_t = i_start_sec + rel_t if rel_t != 0.0 else 0.0
                    
                    time_lbl = f"At local {rel_t:.2f}s (Ref: {master_a_t:.2f}s, Inst: {master_b_t:.2f}s)" if rel_t != 0.0 else "Global Parameter Mismatch"
                    log.write(f" [{am['severity']}] {am['category']} -> {time_lbl}\n")
                    log.write(f"   ↳ {am['desc']}\n\n")
                log.write("===================================================\n\n")
                
                for k in range(NUM_HEADS):
                    name = head_names[k]
                    stats = discrepancies[k]
                    rel_sec = stats['max_time']
                    
                    master_ref_peak_sec = b_start_sec + rel_sec
                    master_inst_peak_sec = i_start_sec + rel_sec
                    
                    log.write(f"     🔹 HEAD #{k}: {name}\n")
                    log.write(f"       - Mean Discrepancy : {stats['mean_diff']:.4f}\n")
                    log.write(f"       - Peak Discrepancy : {stats['max_diff']:.4f}\n")
                    log.write(f"       - Peak Time (Relative)    : {rel_sec:.2f} seconds\n")
                    log.write(f"       - Peak Time (Reference A) : {master_ref_peak_sec:.2f} seconds\n")
                    log.write(f"       - Peak Time (Instance B)  : {master_inst_peak_sec:.2f} seconds\n\n")
                log.write("\n")
                
    print(f"\n💾 [Done] N-Way comparison run complete.")
    print(f"   - Slices and PDF Reports successfully compiled.")
    print(f"   - Summaries saved to: {os.path.abspath(text_report_path)}")


# --- 13. DEMO MIXTAPE GENERATOR ---
def generate_demo_files():
    print("⚠️ [Setup] Generating 3 separate mixtapes to simulate multiple repeats...")
    t_segment = np.arange(int(TARGET_SR * 22)) / TARGET_SR 
    
    bass = 0.5 * np.sin(2 * np.pi * 55 * t_segment)
    keys = 0.4 * np.sin(2 * np.pi * 330 * t_segment)
    vocal = 0.3 * np.sin(2 * np.pi * (880 * t_segment + 3.0 * np.sin(2 * np.pi * 1.0 * t_segment)))
    song_a = bass + keys + vocal
    
    bass_dr = 0.5 * np.sin(2 * np.pi * 55.2 * t_segment)
    keys_dr = 0.4 * np.sin(2 * np.pi * 330 * t_segment)
    vocal_dr = 0.3 * np.sin(2 * np.pi * (885 * t_segment + 3.0 * np.sin(2 * np.pi * 1.05 * t_segment)))
    song_b = bass_dr + keys_dr + vocal_dr
    
    bass_mod = 0.5 * np.sin(2 * np.pi * 55.4 * t_segment)
    keys_mod = 0.4 * np.sin(2 * np.pi * 330 * t_segment)
    vocal_mod = 0.3 * np.sin(2 * np.pi * (878 * t_segment + 3.0 * np.sin(2 * np.pi * 0.98 * t_segment)))
    song_c = bass_mod + keys_mod + vocal_mod
    
    mixtape_1 = np.zeros(int(TARGET_SR * 30))
    mixtape_1[int(TARGET_SR * 3) : int(TARGET_SR * 3) + len(song_a)] = song_a
    
    mixtape_2 = np.zeros(int(TARGET_SR * 30))
    mixtape_2[int(TARGET_SR * 6) : int(TARGET_SR * 6) + len(song_b)] = song_b
    
    mixtape_3 = np.zeros(int(TARGET_SR * 30))
    mixtape_3[int(TARGET_SR * 1) : int(TARGET_SR * 1) + len(song_c)] = song_c
    
    for name, data in [("nway_mixtape_1.wav", mixtape_1), ("nway_mixtape_2.wav", mixtape_2), ("nway_mixtape_3.wav", mixtape_3)]:
        scaled = np.clip(data, -1.0, 1.0) * 32767.0
        wav_write(name, TARGET_SR, scaled.astype(np.int16))
        
    return ["nway_mixtape_1.wav", "nway_mixtape_2.wav", "nway_mixtape_3.wav"]


